# Copy to .env and fill in values. Do not commit .env.

# Antigravity (Google) OAuth — required for Antigravity connect / token exchange
# Public client id used by Antigravity-style editors (register your own app if needed):
# ANTIGRAVITY_CLIENT_ID=1071006060591-tmhssin2h21lcre235vtolojh4g403ep.apps.googleusercontent.com
ANTIGRAVITY_CLIENT_ID=
ANTIGRAVITY_CLIENT_SECRET=

# Optional — public OAuth app identifiers (defaults match upstream apps)
# CLAUDE_CODE_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
